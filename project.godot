; Engine configuration file.
; It's best edited using the Godot editor itself,
; since it preserves the tab structure and comments.
;
; Format:
;   Lines starting with ; are comments.
;   Sections are defined with [section_name]
;   Keys are defined as key=value

[application]

config/name="Mobile Game Demo"
config/run/main_scene=""
config/icon=""

[display]

window/size/width=720
window/size/height=1280
window/mode=2
window/always_on_top=false

[input]

move_left={
"deadzone": 0.05,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"pressed":false,"scancode":65,"unicode":0,"echo":false,"script":null)
]
}
move_right={
"deadzone": 0.05,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"pressed":false,"scancode":68,"unicode":0,"echo":false,"script":null)
]
}
move_forward={
"deadzone": 0.05,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"pressed":false,"scancode":87,"unicode":0,"echo":false,"script":null)
]
}
move_backward={
"deadzone": 0.05,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"pressed":false,"scancode":83,"unicode":0,"echo":false,"script":null)
]
}

[mobile]

touch/joystick_enabled=true
touch/joystick_visible=true
